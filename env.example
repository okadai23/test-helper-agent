# Copy this file to `.env` and edit.

# -----------------------------------------------------------------------------
# Logging settings (from LoggingSettings)
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"                     # One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="json"                    # One of: json, console, plain
# LOG_FILE_PATH="./logs/app.log"     # Optional: path to local log file

# OpenTelemetry logs
OTEL_LOGS_EXPORT_MODE="file"         # One of: file, otlp, both
OTEL_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="python-app"
OTEL_EXPORT_TIMEOUT=30000            # Milliseconds

# -----------------------------------------------------------------------------
# Interface settings (from InterfaceSettings)
# -----------------------------------------------------------------------------
INTERFACE_TYPE="cli"                 # One of: cli, restapi

# -----------------------------------------------------------------------------
# E2E Test Automation settings (from E2ESettings)
# -----------------------------------------------------------------------------
E2E_DATA_PATH="data"
DEFAULT_BROWSER="chromium"           # One of: chromium, firefox, webkit
DEFAULT_HEADLESS=true
DEFAULT_VIEWPORT_WIDTH=1280
DEFAULT_VIEWPORT_HEIGHT=720

# Playwright MCP
PLAYWRIGHT_MCP_PORT=3001

# Test generation/fix timeouts (milliseconds)
TEST_GENERATION_TIMEOUT=5000
TEST_FIX_TIMEOUT=10000

# Storage and resource limits
RETENTION_DAYS=30
MAX_TEST_FILES=100
MAX_MEMORY_MB=2048

# Temporal
TEMPORAL_NAMESPACE="default"
TEMPORAL_HOST="localhost:7233"

# OpenAI
# OPENAI_API_KEY=""                  # Optional: set when using real SDK
OPENAI_MODEL="gpt-4o-mini"           # Allowed: gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-5, gpt-5-mini, gpt-5-nano

# Backends (mock for local/dev; sdk to use real services)
AGENT_BACKEND="mock"                 # One of: mock, sdk
TEMPORAL_BACKEND="mock"              # One of: mock, sdk
