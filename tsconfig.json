{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["@playwright/test", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./tests/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.spec.ts",
    "tests/**/*.ts",
    "data/generated_tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".venv",
    "build",
    "dist"
  ]
}